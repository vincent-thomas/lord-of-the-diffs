#!/usr/bin/env bash
set -euo pipefail

# agent-manager — simple orchestrator for planner → user approval → coder
#
# Usage: agent-manager "Add user authentication"
#
# Environment: Requires LOTD_CONFIG_FILE for GitHub App authentication

if [[ $# -eq 0 ]]; then
  echo "Usage: agent-manager <prompt>"
  echo "Example: agent-manager \"Add user authentication\""
  exit 1
fi

# Validate LOTD_CONFIG_FILE
if [[ -z "${LOTD_CONFIG_FILE:-}" ]]; then
  echo "Error: LOTD_CONFIG_FILE environment variable not set" >&2
  echo "This is required for git authentication as the GitHub App identity" >&2
  exit 1
fi

if [[ ! -f "$LOTD_CONFIG_FILE" ]]; then
  echo "Error: LOTD_CONFIG_FILE points to non-existent file: $LOTD_CONFIG_FILE" >&2
  exit 1
fi

PROMPT="$*"
PLAN_FILE="plan.json"

echo ""
echo "┌─ Step 1: Planning"
echo "└─ Running agent-planner..."
echo ""

# Run planner
if ! nix run .#planner -- "$PROMPT"; then
  echo ""
  echo "✗ Planning failed"
  exit 1
fi

echo ""
echo "✓ Plan created"
echo ""

# Show plan to user
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "PLAN:"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

WHAT=$(jq -r '.what' "$PLAN_FILE")
WHY=$(jq -r '.why' "$PLAN_FILE")
TASK_COUNT=$(jq '.tasks | length' "$PLAN_FILE")

echo "What: $WHAT"
echo ""
echo "Why: $WHY"
echo ""
echo "Tasks ($TASK_COUNT):"

for ((i=0; i<TASK_COUNT; i++)); do
  TITLE=$(jq -r ".tasks[$i].title" "$PLAN_FILE")
  echo "  $((i+1)). $TITLE"
done

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Ask user for approval
read -p "Accept this plan? (y/n): " -n 1 -r
echo ""

if [[ ! $REPLY =~ ^[Yy]$ ]]; then
  echo ""
  echo "✗ Plan rejected"
  echo "Cleaning up..."
  rm -f "$PLAN_FILE"
  exit 1
fi

echo ""
echo "✓ Plan accepted"
echo ""
echo "┌─ Step 2: Implementation"
echo "└─ Running agent-coder for each task..."
echo ""

# Run coder for each task
for ((i=0; i<TASK_COUNT; i++)); do
  nix run .#coder -- ./plan.json $i
done

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "✓ All $TASK_COUNT tasks completed"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "Next steps:"
echo "  - Review commits: git log"
echo "  - Validate: agent-validator"
echo "  - Push: git push or push_and_check_ci"
echo ""
