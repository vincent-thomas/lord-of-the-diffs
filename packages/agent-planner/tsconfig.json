{
  "compilerOptions": {
    "target": "ES2023",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "verbatimModuleSyntax": true,
    "rewriteRelativeImportExtensions": true,
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "noCheck": true,
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": ["*.ts", "extensions/**/*.ts"],
  "exclude": ["*.test.ts", "dist"]
}
