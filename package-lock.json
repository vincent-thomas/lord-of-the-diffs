{
	"name": "vt-pi",
	"version": "0.0.0",
	"lockfileVersion": 3,
	"requires": true,
	"packages": {
		"": {
			"name": "vt-pi",
			"version": "0.0.0",
			"workspaces": [
				"pi/lib",
				"pi/extensions/*",
				"packages/*"
			]
		},
		"node_modules/@vt-pi/command-policy": {
			"resolved": "packages/command-policy",
			"link": true
		},
		"node_modules/@vt-pi/ext-command-policy": {
			"resolved": "pi/extensions/command-policy",
			"link": true
		},
		"node_modules/@vt-pi/lib": {
			"resolved": "pi/lib",
			"link": true
		},
		"packages/command-policy": {
			"name": "@vt-pi/command-policy",
			"version": "0.0.0"
		},
		"pi/extensions/command-policy": {
			"name": "@vt-pi/ext-command-policy",
			"version": "0.0.0",
			"dependencies": {
				"@vt-pi/command-policy": "*",
				"@vt-pi/lib": "*"
			}
		},
		"pi/lib": {
			"name": "@vt-pi/lib",
			"version": "0.0.0"
		}
	}
}
